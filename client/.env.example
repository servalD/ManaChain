# --- API back (inliné au build : passer en build-arg pour l'image Docker) ---
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# --- Dynamic SDK (connexion wallet) ---
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=

# --- Web3 (Avalanche Fuji) ---
# RPC optionnel : vide = RPC public Fuji de viem/chains. En local contre anvil,
# utiliser http://localhost:8545 + NEXT_PUBLIC_CHAIN_ID=31337 (jamais en prod).
NEXT_PUBLIC_RPC_URL=
NEXT_PUBLIC_CHAIN_ID=43113
# Adresses des contrats plateforme (cf. contracts/config/deploy.json > deployed).
# Les adresses par-marque (vault, escrow, supportToken) viennent de l'API.
NEXT_PUBLIC_MANA_ADMIN_ADDRESS=
NEXT_PUBLIC_BRAND_FACTORY_ADDRESS=
NEXT_PUBLIC_SALE_FACTORY_ADDRESS=
NEXT_PUBLIC_EVENT_FACTORY_ADDRESS=
NEXT_PUBLIC_USDC_ADDRESS=

# --- Pinata IPFS ---
# L'upload/delete passe désormais par le back (PINATA_JWT y vit, voir
# back/.env.example) ; le gateway reste ici pour l'affichage des CID.
NEXT_PUBLIC_PINATA_GATEWAY=

# --- Monitoring ---
# DSN Sentry front (public par nature, inlinée au build). Vide = désactivé.
NEXT_PUBLIC_SENTRY_DSN=
