# --- API back (inliné au build : passer en build-arg pour l'image Docker) ---
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# --- Dynamic SDK (connexion wallet) ---
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=

# --- Pinata IPFS ---
# PINATA_JWT est utilisé côté serveur uniquement (runtime, jamais dans le bundle).
PINATA_JWT=
NEXT_PUBLIC_PINATA_GATEWAY=

# --- Monitoring ---
# DSN Sentry front (public par nature, inlinée au build). Vide = désactivé.
NEXT_PUBLIC_SENTRY_DSN=
