# Stack de dev Docker (back/docker/docker-compose.dev.yml).
# Copier vers back/.env.dev puis ajuster. Partagé par le service `db` (POSTGRES_*)
# et le back (DATABASE_*), qui doivent rester cohérents.

# --- Application ---
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000

# --- Postgres (service `db` du compose) ---
POSTGRES_DB=manachain
POSTGRES_USER=manachain
POSTGRES_PASSWORD=manachain

# --- Connexion du back à Postgres (host = nom du service compose) ---
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=manachain
DATABASE_USER=manachain
DATABASE_PASSWORD=manachain

# --- JWT applicatif (mêmes valeurs que l'Express si bascule strangler) ---
APP_JWT_SECRET=dev-secret-change-me-min-16-chars
APP_JWT_EXPIRES_IN=7d

# --- URLs front / API ---
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001/api

# --- SMTP (vide = mode simulation : emails loggés) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@mana-chain.com

# --- Google OAuth (optionnel) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Monitoring ---
# Laisser vide pour désactiver Sentry (dev local, CI).
SENTRY_DSN=

# --- chain-sync (miroir SQL de la chaîne, Avalanche Fuji) ---
# false par défaut : les e2e/dev n'ont pas besoin d'un RPC pour démarrer.
CHAIN_SYNC_ENABLED=false
CHAIN_RPC_URL=
CHAIN_ID=43113
CHAIN_SYNC_POLL_INTERVAL_MS=5000
CHAIN_SYNC_CONFIRMATIONS=2
# Bloc de départ du redéploiement Fuji (cf. contracts/config/deploy.json).
CHAIN_SYNC_START_BLOCK=0
MANA_ADMIN_ADDRESS=
BRAND_FACTORY_ADDRESS=
SALE_FACTORY_ADDRESS=
EVENT_FACTORY_ADDRESS=
USDC_ADDRESS=
