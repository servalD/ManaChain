    {
      "name": "Brand Applications",
      "description": "Brand application submission and admin review endpoints",
      "item": [
        {
          "name": "Create Brand Application",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contact_email\": \"contact@mybrand.com\",\n  \"contact_first_name\": \"John\",\n  \"contact_last_name\": \"Doe\",\n  \"contact_phone\": \"+33612345678\",\n  \"brand_name\": \"My Awesome Brand\",\n  \"interest_ids\": [\"interest-uuid-1\", \"interest-uuid-2\"],\n  \"description\": \"We create sustainable fashion for the modern generation.\",\n  \"website_url\": \"https://mybrand.com\",\n  \"logo_url\": \"https://mybrand.com/logo.png\",\n  \"business_registration_number\": \"123456789\",\n  \"country\": \"France\",\n  \"headquarters_street\": \"123 Fashion Street\",\n  \"headquarters_city\": \"Paris\",\n  \"headquarters_zip_code\": \"75001\",\n  \"headquarters_address_complement\": \"Building A\",\n  \"registration_proof_url\": \"https://storage.com/proof.pdf\",\n  \"motivation\": \"We want to build a passionate community around sustainable fashion.\",\n  \"estimated_community_size\": 10000,\n  \"social_media_links\": {\n    \"instagram\": \"https://instagram.com/mybrand\",\n    \"twitter\": \"https://twitter.com/mybrand\",\n    \"linkedin\": \"https://linkedin.com/company/mybrand\",\n    \"facebook\": \"https://facebook.com/mybrand\",\n    \"tiktok\": \"https://tiktok.com/@mybrand\",\n    \"youtube\": \"https://youtube.com/@mybrand\"\n  },\n  \"how_did_you_hear_about_us\": \"Social media\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/brands/applications",
              "host": ["{{base_url}}"],
              "path": ["brands", "applications"]
            }
          },
          "description": "Public endpoint - Submit a new brand application (no authentication required)"
        },
        {
          "name": "List Brand Applications",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/brands/applications?limit=20&offset=0&status=pending",
              "host": ["{{base_url}}"],
              "path": ["brands", "applications"],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "offset",
                  "value": "0"
                },
                {
                  "key": "status",
                  "value": "pending",
                  "description": "pending, approved, rejected, needs_review"
                },
                {
                  "key": "search",
                  "value": "",
                  "disabled": true,
                  "description": "Search by email or brand name"
                }
              ]
            }
          },
          "description": "Admin only - List all brand applications with pagination and filters"
        },
        {
          "name": "Get Brand Application",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/brands/applications/:id",
              "host": ["{{base_url}}"],
              "path": ["brands", "applications", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "",
                  "description": "Application ID"
                }
              ]
            }
          },
          "description": "Admin only - Get full details of a brand application"
        },
        {
          "name": "Approve Brand Application",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/brands/applications/:id/approve",
              "host": ["{{base_url}}"],
              "path": ["brands", "applications", ":id", "approve"],
              "variable": [
                {
                  "key": "id",
                  "value": "",
                  "description": "Application ID"
                }
              ]
            }
          },
          "description": "Admin only - Approve application and create brand account. This will:\n- Generate secure credentials\n- Create user account (role: BRANDUSER)\n- Create brand profile\n- Send approval email with credentials"
        },
        {
          "name": "Reject Brand Application",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rejection_reason\": \"The business registration document is not legible. Please upload a higher quality scan or official certificate.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/brands/applications/:id/reject",
              "host": ["{{base_url}}"],
              "path": ["brands", "applications", ":id", "reject"],
              "variable": [
                {
                  "key": "id",
                  "value": "",
                  "description": "Application ID"
                }
              ]
            }
          },
          "description": "Admin only - Reject application with reason. This will:\n- Update application status to rejected\n- Record rejection reason\n- Send rejection email to brand"
        }
      ]
    }
  ]
