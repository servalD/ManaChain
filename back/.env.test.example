# Tests e2e contre le Postgres éphémère (back/docker/docker-compose.test.yml, port 5433).
# Copier vers back/.env.test.

NODE_ENV=test
PORT=3001
CORS_ORIGIN=http://localhost:3000

# Postgres éphémère exposé sur 5433
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_NAME=manachain_test
DATABASE_USER=manachain_test
DATABASE_PASSWORD=manachain_test

APP_JWT_SECRET=test-secret-change-me-min-16-chars
APP_JWT_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001/api

# RESEND_API_KEY non configuré → mode simulation pendant les tests
EMAIL_FROM=noreply@mana-chain.com
