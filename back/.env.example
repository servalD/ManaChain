# --- Application ---
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000

# --- Base Postgres (connexion directe à l'instance Supabase pendant le strangler) ---
# Récupérer les identifiants dans Supabase > Project Settings > Database.
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=manachain
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# --- JWT applicatif ---
# DOIT être identique au JWT_SECRET de l'Express actuel (server/) pour valider
# les jetons déjà émis sans forcer une reconnexion.
APP_JWT_SECRET=change-me-with-the-same-secret-as-express
APP_JWT_EXPIRES_IN=7d

# --- URLs front / API (liens emails, redirections OAuth) ---
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001/api

# --- SMTP (emails transactionnels) ---
# Laisser vide pour le mode simulation (les emails sont loggés, pas envoyés).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@mana-chain.com

# --- Google OAuth (optionnel) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Monitoring ---
# Laisser vide pour désactiver Sentry (dev local, CI).
SENTRY_DSN=
