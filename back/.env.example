# --- Application ---
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000

# --- Base Postgres (connexion directe à l'instance Supabase pendant le strangler) ---
# Récupérer les identifiants dans Supabase > Project Settings > Database.
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=manachain
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# --- JWT applicatif ---
# DOIT être identique au JWT_SECRET de l'Express actuel (server/) pour valider
# les jetons déjà émis sans forcer une reconnexion.
APP_JWT_SECRET=change-me-with-the-same-secret-as-express
APP_JWT_EXPIRES_IN=7d

# --- 2FA TOTP ---
# Clé de chiffrement du secret TOTP en base (AES-256-GCM). ≥32 caractères,
# distincte de APP_JWT_SECRET.
TWO_FACTOR_ENCRYPTION_KEY=change-me-32-characters-minimum

# --- URLs front / API (liens emails, redirections OAuth) ---
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001/api

# --- Resend (emails transactionnels) ---
# Laisser vide pour le mode simulation (les emails sont loggés, pas envoyés).
RESEND_API_KEY=
EMAIL_FROM=noreply@mana-chain.com

# --- Google OAuth (optionnel) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Monitoring ---
# Laisser vide pour désactiver Sentry (dev local, CI).
SENTRY_DSN=

# --- chain-sync (miroir SQL de la chaîne, Avalanche Fuji) ---
# false par défaut : les e2e/dev n'ont pas besoin d'un RPC pour démarrer.
CHAIN_SYNC_ENABLED=false
CHAIN_RPC_URL=
CHAIN_ID=43113
CHAIN_SYNC_POLL_INTERVAL_MS=5000
CHAIN_SYNC_CONFIRMATIONS=2
# Bloc de départ du redéploiement Fuji (cf. contracts/config/deploy.json).
CHAIN_SYNC_START_BLOCK=0
MANA_ADMIN_ADDRESS=
BRAND_FACTORY_ADDRESS=
SALE_FACTORY_ADDRESS=
EVENT_FACTORY_ADDRESS=
USDC_ADDRESS=
