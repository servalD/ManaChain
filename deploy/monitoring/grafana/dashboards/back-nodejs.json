{
  "uid": "manachain-back-nodejs",
  "title": "ManaChain / Back (Node.js)",
  "tags": ["manachain", "back", "nodejs"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Event loop lag (p50/p90/p99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "nodejs_eventloop_lag_p50_seconds{job=\"back\"}",
          "legendFormat": "p50 {{instance}}"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "nodejs_eventloop_lag_p90_seconds{job=\"back\"}",
          "legendFormat": "p90 {{instance}}"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "nodejs_eventloop_lag_p99_seconds{job=\"back\"}",
          "legendFormat": "p99 {{instance}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Heap V8 (utilisé / total)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "bytes", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "nodejs_heap_size_used_bytes{job=\"back\"}",
          "legendFormat": "utilisé {{instance}}"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "nodejs_heap_size_total_bytes{job=\"back\"}",
          "legendFormat": "total {{instance}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Durée GC (rate 5m)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(nodejs_gc_duration_seconds_sum{job=\"back\"}[5m])",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Mémoire résidente du process",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "process_resident_memory_bytes{job=\"back\"}",
          "legendFormat": "{{instance}}"
        }
      ]
    }
  ]
}
