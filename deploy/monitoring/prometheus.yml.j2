# ---------------------------------------------------------------------------
# Config Prometheus de la stack ManaChain. Rendu par Ansible (deploy.yml) vers
# {{ stack_dir }}/monitoring/prometheus.yml.
#
# Découverte via dockerswarm_sd (role: tasks) plutôt que le DNS tasks.<svc> :
# __meta_dockerswarm_node_hostname donne des noms de nœuds lisibles en label
# `instance` (le DNS Swarm ne donne que des IPs). keep sur
# network_name={{ stack_name }}_edge (Swarm préfixe les réseaux non-external
# avec le nom de la stack, comme les services) pour éviter les doublons de
# cible (un service peut être attaché à plusieurs réseaux, dont l'ingress
# interne de Swarm).
# ---------------------------------------------------------------------------
global:
  scrape_interval: 30s

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets: ['localhost:9090']

  - job_name: nodes
    dockerswarm_sd_configs:
      - host: unix:///var/run/docker.sock
        role: tasks
        port: 9100
    relabel_configs:
      - source_labels: [__meta_dockerswarm_task_desired_state]
        regex: running
        action: keep
      - source_labels: [__meta_dockerswarm_service_name]
        regex: {{ stack_name }}_node-exporter
        action: keep
      - source_labels: [__meta_dockerswarm_network_name]
        regex: {{ stack_name }}_edge
        action: keep
      - source_labels: [__meta_dockerswarm_node_hostname]
        target_label: instance

  - job_name: containers
    dockerswarm_sd_configs:
      - host: unix:///var/run/docker.sock
        role: tasks
        port: 8080
    relabel_configs:
      - source_labels: [__meta_dockerswarm_task_desired_state]
        regex: running
        action: keep
      - source_labels: [__meta_dockerswarm_service_name]
        regex: {{ stack_name }}_cadvisor
        action: keep
      - source_labels: [__meta_dockerswarm_network_name]
        regex: {{ stack_name }}_edge
        action: keep
      - source_labels: [__meta_dockerswarm_node_hostname]
        target_label: instance

  - job_name: traefik
    dockerswarm_sd_configs:
      - host: unix:///var/run/docker.sock
        role: tasks
        port: 8082
    relabel_configs:
      - source_labels: [__meta_dockerswarm_task_desired_state]
        regex: running
        action: keep
      - source_labels: [__meta_dockerswarm_service_name]
        regex: {{ stack_name }}_traefik
        action: keep
      - source_labels: [__meta_dockerswarm_network_name]
        regex: {{ stack_name }}_edge
        action: keep
      # traefik publie 80/443 (mode host) : dockerswarm_sd génère un target
      # par port publié plutôt que d'utiliser le `port: 8082` ci-dessus (qui
      # ne s'applique qu'aux tâches SANS port publié) — on garde l'IP déjà
      # découverte (overlay edge, la seule routable depuis Prometheus — pas
      # __meta_dockerswarm_node_address, qui est l'IP VNet du nœud) et on
      # ne change que le port.
      - source_labels: [__address__]
        regex: '([^:]+):\d+'
        target_label: __address__
        replacement: ${1}:8082
      - source_labels: [__meta_dockerswarm_node_hostname]
        target_label: instance

  - job_name: back
    dockerswarm_sd_configs:
      - host: unix:///var/run/docker.sock
        role: tasks
        port: 3001
    relabel_configs:
      - source_labels: [__meta_dockerswarm_task_desired_state]
        regex: running
        action: keep
      - source_labels: [__meta_dockerswarm_service_name]
        regex: {{ stack_name }}_back
        action: keep
      - source_labels: [__meta_dockerswarm_network_name]
        regex: {{ stack_name }}_edge
        action: keep
      - source_labels: [__meta_dockerswarm_node_hostname]
        target_label: instance
