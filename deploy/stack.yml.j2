# ---------------------------------------------------------------------------
# Stack Docker Swarm de production ManaChain.
#
# Template Jinja2 rendu par Ansible (infra/ansible/deploy.yml) avec les
# variables d'infra (domaine, ACR, hôte Postgres managé Azure) puis appliqué
# via `docker stack deploy`. Les valeurs sensibles ne transitent JAMAIS par ce
# fichier : elles sont des secrets Swarm consommés via les variables *_FILE
# (résolues par le docker-entrypoint.sh des images).
#
# Topologie (3 nœuds : 1 manager + 2 workers) :
#   - traefik épinglé sur le manager (IP publique + volume des certificats ACME)
#   - back et client ×2 replicas sur les workers, 1 replica max par nœud
#   - pas de Postgres dans la stack : Azure Database for PostgreSQL (managé)
# ---------------------------------------------------------------------------
version: "3.8"

services:
  traefik:
    # >= v3.6.1 obligatoire : les versions antérieures figent l'API Docker à
    # 1.24 (refusée par Docker Engine 29+) ; v3.6.1+ négocie automatiquement.
    image: traefik:v3.6
    command:
      - --providers.swarm.endpoint=unix:///var/run/docker.sock
      - --providers.swarm.exposedByDefault=false
      - --entrypoints.web.address=:80
      - --entrypoints.websecure.address=:443
      # Redirection globale HTTP → HTTPS.
      - --entrypoints.web.http.redirections.entrypoint.to=websecure
      - --entrypoints.web.http.redirections.entrypoint.scheme=https
      # Certificats Let's Encrypt (challenge HTTP sur :80).
      - --certificatesresolvers.letsencrypt.acme.email={{ acme_email }}
      - --certificatesresolvers.letsencrypt.acme.storage=/letsencrypt/acme.json
      - --certificatesresolvers.letsencrypt.acme.httpchallenge.entrypoint=web
      # Métriques edge (req/s, latences, codes par router) — scrapées par
      # Prometheus sur l'overlay ; :8082 n'est jamais publié sur l'hôte.
      - --metrics.prometheus=true
      - --metrics.prometheus.entrypoint=metrics
      - --metrics.prometheus.addRoutersLabels=true
      - --entrypoints.metrics.address=:8082
      - --ping=true
    ports:
      # Mode host : préserve l'IP source et évite un saut de routing mesh ;
      # possible car traefik est contraint sur le manager (qui porte l'IP publique).
      - target: 80
        published: 80
        mode: host
      - target: 443
        published: 443
        mode: host
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - traefik_letsencrypt:/letsencrypt
    networks:
      - edge
    healthcheck:
      test: ["CMD", "traefik", "healthcheck", "--ping"]
      interval: 10s
      timeout: 5s
      retries: 3
    deploy:
      placement:
        constraints:
          - node.role == manager
      restart_policy:
        condition: any
        delay: 5s

  back:
    image: "{{ acr_login_server }}/manachain-back:{{ back_image_tag }}"
    environment:
      NODE_ENV: production
      PORT: "3001"
      CORS_ORIGIN: https://{{ domain_name }}
      FRONTEND_URL: https://{{ domain_name }}
      API_URL: https://{{ domain_name }}/api
      DATABASE_HOST: "{{ database_host }}"
      DATABASE_PORT: "5432"
      DATABASE_NAME: "{{ database_name }}"
      DATABASE_USER: "{{ database_user }}"
      DATABASE_SSL: "true"
      APP_JWT_EXPIRES_IN: 7d
      # Vide ("") → mode simulation des emails, comme en dev.
      EMAIL_FROM: "{{ email_from | default('noreply@mana-chain.com') }}"
      GOOGLE_CLIENT_ID: "{{ google_client_id | default('') }}"
      SENTRY_DSN: "{{ sentry_dsn_back | default('') }}"
      DATABASE_PASSWORD_FILE: /run/secrets/database_password
      APP_JWT_SECRET_FILE: /run/secrets/app_jwt_secret
      TWO_FACTOR_ENCRYPTION_KEY_FILE: /run/secrets/two_factor_encryption_key
      RESEND_API_KEY_FILE: /run/secrets/resend_api_key
      GOOGLE_CLIENT_SECRET_FILE: /run/secrets/google_client_secret
    secrets:
      - database_password
      - app_jwt_secret
      - two_factor_encryption_key
      - resend_api_key
      - google_client_secret
    networks:
      - edge
    deploy:
      replicas: 2
      placement:
        constraints:
          - node.role == worker
        max_replicas_per_node: 1
      update_config:
        order: start-first
        parallelism: 1
      restart_policy:
        condition: any
        delay: 5s
      labels:
        - traefik.enable=true
        # Priorité explicite : sans elle, traefik classe par longueur de règle
        # et la règle du client (apex + www) passerait devant /api.
        - traefik.http.routers.back.rule=Host(`{{ domain_name }}`) && PathPrefix(`/api`)
        - traefik.http.routers.back.priority=100
        - traefik.http.routers.back.entrypoints=websecure
        - traefik.http.routers.back.tls.certresolver=letsencrypt
        - traefik.http.services.back.loadbalancer.server.port=3001

  client:
    image: "{{ acr_login_server }}/manachain-client:{{ client_image_tag }}"
    environment:
      PINATA_JWT_FILE: /run/secrets/pinata_jwt
    secrets:
      - pinata_jwt
    networks:
      - edge
    deploy:
      replicas: 2
      placement:
        constraints:
          - node.role == worker
        max_replicas_per_node: 1
      update_config:
        order: start-first
        parallelism: 1
      restart_policy:
        condition: any
        delay: 5s
      labels:
        - traefik.enable=true
        # Couvre aussi www (le DNS y pointe) : traefik demande un certificat
        # pour chaque Host de la règle. !PathPrefix(/health) exclut le
        # healthcheck du client de l'exposition publique (usage Docker
        # interne uniquement) ; priorités explicites sur back ET client :
        # on ne dépend plus du tri par longueur de règle de traefik.
        - traefik.http.routers.client.rule=(Host(`{{ domain_name }}`) || Host(`www.{{ domain_name }}`)) && !PathPrefix(`/health`)
        - traefik.http.routers.client.priority=1
        - traefik.http.routers.client.entrypoints=websecure
        - traefik.http.routers.client.tls.certresolver=letsencrypt
        - traefik.http.services.client.loadbalancer.server.port=3000

  prometheus:
    image: prom/prometheus:v3.5.0
    command:
      - --config.file=/etc/prometheus/prometheus.yml
      - --storage.tsdb.path=/prometheus
      - --storage.tsdb.retention.time=10d
      - --storage.tsdb.retention.size=2GB
    volumes:
      - {{ stack_dir }}/monitoring/prometheus.yml:/etc/prometheus/prometheus.yml:ro
      # dockerswarm_sd_configs a besoin du socket pour découvrir les tâches.
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - prometheus_data:/prometheus
    # L'image tourne en non-root (uid nobody) par défaut : sans ça, la
    # lecture du socket échoue en permission denied. group_add n'est pas
    # supporté par docker stack deploy (contrairement à docker compose) —
    # root est la façon simple de donner l'accès en mode stack.
    user: "0"
    networks:
      - edge
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://localhost:9090/-/healthy"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 60s # replay du WAL au démarrage
    deploy:
      placement:
        constraints:
          - node.role == manager
      resources:
        limits:
          memory: 512M
          cpus: '0.50'
      restart_policy:
        condition: any
        delay: 5s
      # Aucun label traefik : jamais exposé publiquement (cf. Contexte).

  grafana:
    image: grafana/grafana:12.2.1
    environment:
      GF_SERVER_ROOT_URL: https://grafana.{{ domain_name }}
      GF_SECURITY_ADMIN_PASSWORD__FILE: /run/secrets/grafana_admin_password
      GF_USERS_ALLOW_SIGN_UP: "false"
      GF_AUTH_ANONYMOUS_ENABLED: "false"
    secrets:
      - grafana_admin_password
    volumes:
      - grafana_data:/var/lib/grafana
      - {{ stack_dir }}/monitoring/grafana/provisioning:/etc/grafana/provisioning:ro
      - {{ stack_dir }}/monitoring/grafana/dashboards:/etc/grafana/dashboards:ro
    networks:
      - edge
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://localhost:3000/api/health"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 30s
    deploy:
      placement:
        constraints:
          - node.role == manager
      resources:
        limits:
          memory: 256M
          cpus: '0.30'
      restart_policy:
        condition: any
        delay: 5s
      labels:
        # Seul service de monitoring exposé publiquement — login admin
        # Grafana natif uniquement (pas de basicAuth traefik, cf. Contexte).
        - traefik.enable=true
        - traefik.http.routers.grafana.rule=Host(`grafana.{{ domain_name }}`)
        - traefik.http.routers.grafana.entrypoints=websecure
        - traefik.http.routers.grafana.tls.certresolver=letsencrypt
        - traefik.http.services.grafana.loadbalancer.server.port=3000

  node-exporter:
    image: prom/node-exporter:v1.9.1
    command:
      - --path.rootfs=/rootfs
      - --path.procfs=/host/proc
      - --path.sysfs=/host/sys
    volumes:
      - /proc:/host/proc:ro
      - /sys:/host/sys:ro
      - /:/rootfs:ro
    networks:
      - edge
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://localhost:9100/"]
      interval: 30s
      timeout: 5s
      retries: 3
    deploy:
      mode: global
      resources:
        limits:
          memory: 64M
          cpus: '0.10'
      restart_policy:
        condition: any
        delay: 5s

  cadvisor:
    image: gcr.io/cadvisor/cadvisor:v0.55.1
    command:
      - --docker_only=true
      - --housekeeping_interval=30s
      - --store_container_labels=false
      - --disable_metrics=percpu,sched,tcp,udp,advtcp,hugetlb,referenced_memory,cpu_topology,resctrl,disk
    volumes:
      - /:/rootfs:ro
      - /var/run:/var/run:ro
      - /sys:/sys:ro
      - /var/lib/docker:/var/lib/docker:ro
      - /dev/disk:/dev/disk:ro
    networks:
      - edge
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://localhost:8080/healthz"]
      interval: 30s
      timeout: 5s
      retries: 3
    deploy:
      # Pas de `privileged` (invalide en stack deploy) : fonctionne sans, en cgroup v2.
      mode: global
      resources:
        limits:
          memory: 192M
          cpus: '0.20'
      restart_policy:
        condition: any
        delay: 5s

  # Politique de sauvegarde 3-2-1 : pg_dump quotidien → disque du manager
  # (médium 1) → Azure Blob via rclone (médium 2) → S3/R2 hors Azure (copie
  # externe n°3). Voir deploy/backup.sh.j2. Épinglé sur le manager : les bind
  # mounts (script + dossier de dumps) doivent suivre le même nœud.
  backup:
    image: postgres:16-alpine
    entrypoint: ["/bin/sh", "-c"]
    command:
      - apk add --no-cache rclone >/dev/null && while true; do /backup.sh; sleep 86400; done
    environment:
      DATABASE_HOST: "{{ database_host }}"
      DATABASE_NAME: "{{ database_name }}"
      DATABASE_USER: "{{ database_user }}"
      BACKUP_CONTAINER: "{{ backup_container }}"
    volumes:
      - {{ stack_dir }}/backup.sh:/backup.sh:ro
      - /var/backups/manachain:/backups
    secrets:
      - database_password
      - rclone_conf
    networks:
      - edge
    healthcheck:
      # start_period généreux : le `apk add rclone` tourne au boot du conteneur.
      test: ["CMD-SHELL", "pg_isready -h $$DATABASE_HOST -U $$DATABASE_USER -d $$DATABASE_NAME"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 90s
    deploy:
      placement:
        constraints:
          - node.role == manager
      restart_policy:
        condition: any
        delay: 30s

networks:
  # Un seul overlay suffit : la DB est hors cluster (Azure) et le front parle
  # au back via l'URL publique — aucun trafic interne inter-services.
  edge:
    driver: overlay

volumes:
  # Certificats ACME — reste sur le manager (traefik y est contraint).
  traefik_letsencrypt:
  # prometheus/grafana sont épinglés sur le manager (cf. deploy) : ces
  # volumes locaux suivent le même nœud, pas besoin d'un driver partagé.
  prometheus_data:
  grafana_data:

secrets:
  # Créés/tournés par Ansible (deploy.yml) avant le stack deploy.
  database_password:
    external: true
  app_jwt_secret:
    external: true
  two_factor_encryption_key:
    external: true
  resend_api_key:
    external: true
  google_client_secret:
    external: true
  pinata_jwt:
    external: true
  grafana_admin_password:
    external: true
  rclone_conf:
    external: true
