# Backend REST cible (seed-api.ts). Doit tourner avec :
#   SKIP_EMAIL_VERIFICATION=true
#   BOOTSTRAP_ADMIN_EMAIL=<identique à admin.bootstrapEmail dans contracts/config/demo-seed.json>
#   CHAIN_SYNC_ENABLED=true, CHAIN_RPC_URL pointant sur la même chaîne que --rpc-url (voir run-demo-seed.sh)
BACKEND_API_URL=http://localhost:3001/api

# Clés privées des acteurs on-chain (forge script SeedDemo.s.sol + dérivation d'adresse
# côté seed-api.ts). Une par entité déclarée dans contracts/config/demo-seed.json.
# Local (anvil) : utiliser les clés par défaut affichées au démarrage d'`anvil`.
# Fuji : générer des wallets dédiés, les financer en AVAX (faucet testnet, manuel) et USDC
# (scriptable via MockUSDC.mint, cf. SeedDemo.s.sol).
PK_ADMIN_OPERATOR=
PK_BRAND_1=
PK_BRAND_2=
PK_CLIENT_1=
PK_CLIENT_2=
